{
  "name": "@ttt/ai-service",
  "version": "0.3.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --loader ts-node/esm --watch src/server.ts",
    "build": "node esbuild.config.mjs",
    "build:tsc": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "deploy": "firebase deploy --only functions"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@ttt/engine": "^0.3.0",
    "express": "^4.19.2",
    "zod": "^3.23.8",
    "@genkit-ai/core": "^1.19.2",
    "@google/generative-ai": "^0.11.0",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.2.3"
  },
  "devDependencies": {
    "dotenv": "^16.5.0",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
