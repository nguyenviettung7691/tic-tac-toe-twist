PORT=9191
# For Google Gemini provider (if you wire it):
GOOGLE_GENAI_API_KEY=
GOOGLE_GENAI_MODEL=gemini-2.5-flash-lite

# ── Firebase Cloud Functions deployment ────────────────────────
# The API key is managed via Firebase secrets for deployed functions:
#   firebase functions:secrets:set GOOGLE_GENAI_API_KEY
#
# After deploying, the function URL will be printed to the console.
# Set API_BASE_URL in the mobile app environment or use setApiBaseUrl()
# to point the mobile app at the deployed function.
#
# Deploy with:
#   npm run deploy:ai            (from repo root)
#   firebase deploy --only functions  (from repo root)